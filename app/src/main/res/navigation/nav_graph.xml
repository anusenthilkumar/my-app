<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- LOGIN SCREEN -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.guardianangel.ui.auth.LoginFragment"
        android:label="Login"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_loginFragment_to_mainFragment"
            app:destination="@id/mainFragment"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- MAIN SCREEN (Contains SOS, Dashboard, Contacts, Settings) -->
    <fragment
        android:id="@+id/mainFragment"
        android:name="com.example.guardianangel.ui.main.MainFragment"
        android:label="Main"
        tools:layout="@layout/fragment_main">

        <!-- THIS WAS MISSING: The road back to Login -->
        <action
            android:id="@+id/action_mainFragment_to_loginFragment"
            app:destination="@id/loginFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

</navigation>